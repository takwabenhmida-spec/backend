    {
      "name": "🌐 Portail Client",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Script d'extraction automatique du token si l'utilisateur colle une URL",
              "let token = pm.collectionVariables.get('clientToken');",
              "",
              "if (token && (token.includes('http://') || token.includes('https://'))) {",
              "    console.log('🔗 URL détectée, extraction du token...');",
              "    const parts = token.split('/');",
              "    const extracted = parts[parts.length - 1];",
              "    pm.variables.set('extractedToken', extracted);",
              "    console.log('✅ Token extrait :', extracted);",
              "} else {",
              "    pm.variables.set('extractedToken', token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
