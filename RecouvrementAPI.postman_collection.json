{
  "info": {
    "_postman_id": "stb-recouvrement-api-2026",
    "name": "🏦 STB Recouvrement API",
    "description": "Collection complète pour tester tous les endpoints de l'API de Recouvrement STB.\n\n**AVANT DE COMMENCER :**\n1. Exécuter `Seed Admin` (une seule fois)\n2. Exécuter `Login` → le token JWT sera sauvegardé automatiquement\n3. Tester les autres endpoints (le token est injecté automatiquement)\n\nBase URL : http://localhost:5203",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5203/api",
      "type": "string"
    },
    {
      "key": "bearerToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "clientToken",
      "value": "REMPLACER_PAR_LE_TOKEN_OU_URL_CLIENT",
      "type": "string",
      "description": "Token d'accès (format: tok_xxx) OU URL complète reçue par SMS. Le script extraira automatiquement le code."
    }
  ],
  "item": [
    {
      "name": "🔐 Authentification",
      "item": [
        {
          "name": "Seed Admin (1 seule fois)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/Auth/seed-admin",
              "host": ["{{baseUrl}}"],
              "path": ["Auth", "seed-admin"]
            },
            "description": "Crée le compte administrateur par défaut.\nEmail: admin@stb.tn | Password: admin123\n⚠️ À exécuter UNE SEULE FOIS si la BDD est vide."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('bearerToken', json.token);",
                  "    console.log('✅ Token JWT sauvegardé automatiquement !');",
                  "    console.log('Agent: ' + json.nom + ' ' + json.prenom + ' | Rôle: ' + json.role);",
                  "} else {",
                  "    console.error('❌ Connexion échouée:', pm.response.json());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@stb.tn\",\n  \"motDePasse\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/Auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["Auth", "login"]
            },
            "description": "Authentification de l'agent. Le token JWT est automatiquement sauvegardé dans la variable `bearerToken`."
          }
        }
      ]
    },
